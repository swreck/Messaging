generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())

  // Round C2 — per-user default style for Refine/Polish/generation.
  // Empty string = unset (fall through to org default, then SYSTEM_DEFAULT = TABLE_FOR_2).
  // Values: "" | "TABLE_FOR_2" | "ENGINEERING_TABLE" | "PERSONALIZED"
  defaultStyle String @default("")

  inviteCodeUsed    InviteCode?
  offerings         Offering[]
  audiences         Audience[]
  assistantMessages AssistantMessage[]
  workspaces        WorkspaceMember[]
  styleRules        UserStyleRule[]
}

// Round E2 — Maria learns from your edits.
// When the user makes the same shape of edit three times across recent
// generations, Maria asks one scoped question and (on yes) saves the answer
// here. Rules are scoped to the audience-type and/or format Maria observed
// the pattern in; the user can later broaden them via chat or Settings.
//
// rule:        free-text description of the rule, in user-affirmed phrasing.
// scopeAudienceType / scopeFormat: optional narrowing — empty string means
//   "applies to any audience-type / format" (i.e. broadened scope). The
//   refine/copy-edit pipeline reads matching rules and layers them on top of
//   the active base style + Personalize profile.
// lastApplied: bumped each time a generation actually used the rule. The
//   Settings 30-day-stale prompt reads this.
model UserStyleRule {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule              String
  scopeAudienceType String    @default("")
  scopeFormat       String    @default("")
  createdAt         DateTime  @default(now())
  lastApplied       DateTime?

  @@index([userId])
}

// ─── Workspaces ──────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Round C2 — org-level default style. Org admins set this; users can override
  // per-user in their own Settings. Empty string = unset (fall through to
  // SYSTEM_DEFAULT = TABLE_FOR_2). Values: "" | "TABLE_FOR_2" | "ENGINEERING_TABLE" | "PERSONALIZED"
  defaultStyle String @default("")

  members     WorkspaceMember[]
  offerings   Offering[]
  audiences   Audience[]
  inviteCodes InviteCode[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("editor") // owner | editor | viewer
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model InviteCode {
  id           String     @id @default(cuid())
  code         String     @unique
  shortCode    String?    @unique
  usedById     String?    @unique
  usedBy       User?      @relation(fields: [usedById], references: [id])
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  inviteeName  String     @default("")
  inviteeEmail String     @default("")
  role         String     @default("editor")
  createdAt    DateTime   @default(now())
}

// ─── Offerings ──────────────────────────────────────────

model Offering {
  id                 String     @id @default(cuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId        String?
  workspace          Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  smeRole            String     @default("")
  description        String     @default("")
  contrarianScenario String? // Captured from the contrarian-question turn in the offering interview — kept as honest-framing material the deliverable can use ("we're not the right choice if you're doing X")
  contrarianAsked    Boolean    @default(false) // Whether the contrarian question has been asked for this offering — gates re-asking
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  elements OfferingElement[]
  drafts   ThreeTierDraft[]
}

model OfferingElement {
  id               String   @id @default(cuid())
  offeringId       String
  offering         Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  text             String
  source           String   @default("manual") // manual | ai_extracted
  sortOrder        Int      @default(0)
  motivatingFactor String   @default("") // Why would someone crave this differentiator?

  mappings Mapping[]
}

// ─── Audiences ──────────────────────────────────────────

model Audience {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String     @default("")
  situation   String? // Audience-specific situation captured durably so Maria doesn't re-ask in future sessions
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  priorities Priority[]
  drafts     ThreeTierDraft[]
}

model Priority {
  id                 String   @id @default(cuid())
  audienceId         String
  audience           Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  text               String
  rank               Int      @default(0)
  isSpoken           Boolean  @default(true)
  driver             String   @default("")
  whatAudienceThinks String   @default("")
  sortOrder          Int      @default(0)

  mappings        Mapping[]
  tier2Statements Tier2Statement[]
}

// ─── Three Tier Draft ───────────────────────────────────

model ThreeTierDraft {
  id               String   @id @default(cuid())
  offeringId       String
  offering         Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  audienceId       String
  audience         Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  currentStep      Int      @default(1) // 1-5
  status           String   @default("in_progress") // in_progress | completed
  version          Int      @default(1)
  archived         Boolean  @default(false)
  noStrongPairings Boolean? // True if the most recent mapping evaluation found no STRONG pairings — drives Maria's audience-fit conversation
  // Bundle 1B Rule 9 — example deliverables visually distinguished
  // from user-built content. "real" (default) for user-authored work;
  // "example" for seeded/onboarding content. Existing rows backfill
  // to "real" via the @default. Frontend reads this to render the
  // EXAMPLE tag and to filter out examples from work counts.
  kind             String   @default("real")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mappings        Mapping[]
  tier1Statement  Tier1Statement?
  tier2Statements Tier2Statement[]
  tableVersions   TableVersion[]
  stories         FiveChapterStory[]
  conversations   ConversationMessage[]
  observations    Observation[]
}

model Mapping {
  id             String          @id @default(cuid())
  draftId        String
  draft          ThreeTierDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  priorityId     String
  priority       Priority        @relation(fields: [priorityId], references: [id], onDelete: Cascade)
  elementId      String
  element        OfferingElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  confidence     Float           @default(0.0)
  status         String          @default("suggested") // suggested | confirmed | rejected
  mfRationale    String          @default("") // Maria's per-mapping reasoning: how the differentiator's MF principle applies to this specific audience priority
  strengthSignal String? // STRONG | HONEST_BUT_THIN | EXAGGERATED — the truth-principle rating for this pairing
  failurePattern String? // PATTERN-FROM-HISTORY | CHAIN-OF-REASONING | AUDIENCE-SCOPE-MISMATCH | COMMODITY-CAPABILITY — set when strengthSignal is EXAGGERATED
  createdAt      DateTime        @default(now())
}

// ─── Tier Statements ────────────────────────────────────

model Tier1Statement {
  id      String         @id @default(cuid())
  draftId String         @unique
  draft   ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  text    String

  cellVersions CellVersion[]
}

model Tier2Statement {
  id            String         @id @default(cuid())
  draftId       String
  draft         ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  text          String
  sortOrder     Int            @default(0)
  priorityId    String?
  priority      Priority?      @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  categoryLabel String         @default("")

  tier3Bullets Tier3Bullet[]
  cellVersions CellVersion[]
}

model Tier3Bullet {
  id        String         @id @default(cuid())
  tier2Id   String
  tier2     Tier2Statement @relation(fields: [tier2Id], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int            @default(0)

  cellVersions CellVersion[]
}

// ─── Five Chapter Story ─────────────────────────────────

model FiveChapterStory {
  id            String         @id @default(cuid())
  draftId       String
  draft         ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  medium        String // "email" | "blog" | "social" | "landing_page" | "in_person" | "press_release" | "newsletter" | "report"
  customName    String         @default("")
  sourceStoryId String?
  cta           String
  emphasis      String         @default("")
  stage         String         @default("chapters") // "chapters" | "joined" | "blended"
  joinedText    String         @default("")
  blendedText   String         @default("")
  version       Int            @default(1)
  // Bundle 1B Rule 9 — example tag, mirrors ThreeTierDraft.kind.
  // "real" for user-authored stories; "example" for seeded onboarding
  // content. Existing rows backfill to "real" via the @default.
  kind          String         @default("real")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Round B4 — pre-Chapter-4 peer prompt. Optional named-peer context the user
  // contributed via Maria's pause before Ch4 generation. Empty string = user
  // declined or skipped; non-empty = use as named-peer evidence in Ch4.
  peerInfo  String  @default("")
  peerAsked Boolean @default(false)

  // Round C3 — per-deliverable style override. Empty string = use the user's
  // effective style (user → org → SYSTEM_DEFAULT). Set = override for this
  // deliverable only. Values: "" | "TABLE_FOR_2" | "ENGINEERING_TABLE" | "PERSONALIZED"
  style String @default("")

  chapters      ChapterContent[]
  storyVersions StoryVersion[]
}

model ChapterContent {
  id         String           @id @default(cuid())
  storyId    String
  story      FiveChapterStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapterNum Int // 1-5
  title      String
  content    String

  chapterVersions ChapterVersion[]
  claims          Claim[]

  @@unique([storyId, chapterNum])
}

// Round D — Per-claim provenance. Each substantive claim in a generated
// chapter is tagged with its origin (what backs it). The deliverable view
// surfaces unsourced claims in the lead-with-action banner; the user can
// resolve via Edit / Cut / Add source / Own it.
//
// origin enum stored as a string for migration simplicity (matches the
// rest of the schema's pattern):
//   USER_WORDS  — verbatim from the user's own input (interview, paste).
//   USER_DOC    — pulled from a document the user attached (with locator).
//   RESEARCH    — verified external source (URL); set after Add-source
//                 validation succeeds.
//   INFERENCE   — Maria-drafted from general knowledge or pattern-match;
//                 these are the unsourced claims that need attention.
//   AUTHORED    — user owned it via the "Own it" action.
//
// state enum:
//   OPEN              — awaiting attention (only INFERENCE-origin claims).
//   RESOLVED_EDITED   — user edited the sentence to resolve.
//   RESOLVED_CUT      — sentence removed.
//   RESOLVED_SOURCED  — Add source succeeded; origin flipped to RESEARCH.
//   RESOLVED_OWNED    — user owned it; origin flipped to AUTHORED.
model Claim {
  id               String         @id @default(cuid())
  chapterContentId String
  chapter          ChapterContent @relation(fields: [chapterContentId], references: [id], onDelete: Cascade)
  // The exact sentence text in the chapter content this claim covers.
  // Stored as the literal string so the frontend can locate it for marker
  // placement and the auto-flow scroll-to-next behavior.
  sentence         String
  // Position in the chapter content for stable ordering. Approximate
  // character offset; recomputed on chapter regeneration.
  charOffset       Int            @default(0)
  origin           String         @default("INFERENCE")
  // sourceRef varies by origin: doc id+page for USER_DOC, URL for RESEARCH,
  // empty for USER_WORDS / INFERENCE / AUTHORED.
  sourceRef        String         @default("")
  state            String         @default("OPEN")
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now())

  @@index([chapterContentId, state])
}

// ─── Version History ────────────────────────────────────

model CellVersion {
  id           String          @id @default(cuid())
  tier1Id      String?
  tier1        Tier1Statement? @relation(fields: [tier1Id], references: [id], onDelete: Cascade)
  tier2Id      String?
  tier2        Tier2Statement? @relation(fields: [tier2Id], references: [id], onDelete: Cascade)
  tier3Id      String?
  tier3        Tier3Bullet?    @relation(fields: [tier3Id], references: [id], onDelete: Cascade)
  text         String
  versionNum   Int
  changeSource String          @default("manual") // manual | ai_generate | poetry_pass | refine | magic_hour
  createdAt    DateTime        @default(now())
}

model TableVersion {
  id         String         @id @default(cuid())
  draftId    String
  draft      ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  snapshot   Json
  label      String
  versionNum Int
  createdAt  DateTime       @default(now())
}

model StoryVersion {
  id         String           @id @default(cuid())
  storyId    String
  story      FiveChapterStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  snapshot   Json
  label      String
  versionNum Int
  createdAt  DateTime         @default(now())
}

// ─── Conversation History ───────────────────────────────

model ConversationMessage {
  id        String         @id @default(cuid())
  draftId   String
  draft     ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  step      Int
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime       @default(now())
}

// ─── Assistant Messages ────────────────────────────────

model AssistantMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant"
  content   String
  context   Json     @default("{}")
  action    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// ─── Share Links ───────────────────────────────────────

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique
  draftId   String?
  storyId   String?
  createdBy String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── Chapter Versions ──────────────────────────────────

model ChapterVersion {
  id               String         @id @default(cuid())
  chapterContentId String
  chapter          ChapterContent @relation(fields: [chapterContentId], references: [id], onDelete: Cascade)
  title            String
  content          String
  versionNum       Int
  changeSource     String         @default("manual")
  createdAt        DateTime       @default(now())
}

// ─── Observations (Maria's per-cell suggestions) ──────
// Persistent suggestions Maria has on Three Tier cells. Resolution requires
// either change-the-cell or explicit acknowledge-as-is — the dismiss-without-
// resolution path is gone. Persists across sessions until resolved.
model Observation {
  id         String         @id @default(cuid())
  draftId    String
  draft      ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  cellType   String // tier1 | tier2 | tier3
  cellId     String // Tier1Statement.id or Tier2Statement.id or Tier3Bullet.id
  suggestion String // Maria's suggestion text — what she'd flag if user clicks
  state      String         @default("OPEN") // OPEN | RESOLVED_BY_CHANGE | RESOLVED_BY_ACKNOWLEDGE
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  resolvedAt DateTime?

  @@index([draftId, state])
  @@index([cellType, cellId])
}

// ─── Express Flow Jobs (Maria 3.0) ─────────────────────
// Additive to 2.5. Stores the async pipeline state for Express Flow commits.
// The frontend polls GET /api/express/status/:jobId to show progress, and the
// resultStoryId points at the finished FiveChapterStory when status === 'complete'.
model ExpressJob {
  id              String   @id @default(cuid())
  userId          String
  workspaceId     String
  draftId         String?
  status          String   @default("pending")
  stage           String   @default("")
  progress        Int      @default(0)
  error           String   @default("")
  interpretation  Json
  resultStoryId   String?
  // V4 multi-audience variants. When the interpretation returns 2+ audiences,
  // commitInterpretation creates a ThreeTierDraft per audience (all sharing
  // the same Offering) and the pipeline generates one FiveChapterStory per
  // draft. draftId + resultStoryId still point at the primary (first
  // audience) so the single-variant code path is untouched; variantDraftIds
  // and variantStoryIds hold the full list in audience order. Single-audience
  // jobs leave these null.
  variantDraftIds Json?
  variantStoryIds Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Guided Flow Session (3.0 Maria merge) ─────────────
// Persists GuidedFlow React state so the session survives
// page navigation, browser close, and device switching.
// One active session per user per workspace at a time.

model GuidedSession {
  id          String @id @default(cuid())
  userId      String
  workspaceId String

  phase           String @default("greeting")
  completedStages Json   @default("[]")
  messages        Json   @default("[]")

  intakeAnswers  Json?
  interpretation Json?
  situation      String?

  draftId       String?
  storyId       String?
  foundation    Json?
  backlog       Json    @default("[]")
  lastDraftText String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, workspaceId])
}
