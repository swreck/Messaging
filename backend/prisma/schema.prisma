generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())

  inviteCodeUsed    InviteCode?
  offerings         Offering[]
  audiences         Audience[]
  assistantMessages AssistantMessage[]
  workspaces        WorkspaceMember[]
}

// ─── Workspaces ──────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  offerings   Offering[]
  audiences   Audience[]
  inviteCodes InviteCode[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("editor") // owner | editor | viewer
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model InviteCode {
  id           String     @id @default(cuid())
  code         String     @unique
  shortCode    String?    @unique
  usedById     String?    @unique
  usedBy       User?      @relation(fields: [usedById], references: [id])
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  inviteeName  String     @default("")
  inviteeEmail String     @default("")
  role         String     @default("editor")
  createdAt    DateTime   @default(now())
}

// ─── Offerings ──────────────────────────────────────────

model Offering {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  smeRole     String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  elements OfferingElement[]
  drafts   ThreeTierDraft[]
}

model OfferingElement {
  id               String   @id @default(cuid())
  offeringId       String
  offering         Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  text             String
  source           String   @default("manual") // manual | ai_extracted
  sortOrder        Int      @default(0)
  motivatingFactor String   @default("") // Why would someone crave this differentiator?

  mappings Mapping[]
}

// ─── Audiences ──────────────────────────────────────────

model Audience {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priorities Priority[]
  drafts     ThreeTierDraft[]
}

model Priority {
  id                 String   @id @default(cuid())
  audienceId         String
  audience           Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  text               String
  rank               Int      @default(0)
  isSpoken           Boolean  @default(true)
  driver             String   @default("")
  whatAudienceThinks String   @default("")
  sortOrder          Int      @default(0)

  mappings        Mapping[]
  tier2Statements Tier2Statement[]
}

// ─── Three Tier Draft ───────────────────────────────────

model ThreeTierDraft {
  id          String   @id @default(cuid())
  offeringId  String
  offering    Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  audienceId  String
  audience    Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  currentStep Int      @default(1) // 1-5
  status      String   @default("in_progress") // in_progress | completed
  version     Int      @default(1)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mappings       Mapping[]
  tier1Statement Tier1Statement?
  tier2Statements Tier2Statement[]
  tableVersions  TableVersion[]
  stories        FiveChapterStory[]
  conversations  ConversationMessage[]
}

model Mapping {
  id          String          @id @default(cuid())
  draftId     String
  draft       ThreeTierDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  priorityId  String
  priority    Priority        @relation(fields: [priorityId], references: [id], onDelete: Cascade)
  elementId   String
  element     OfferingElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  confidence  Float           @default(0.0)
  status      String          @default("suggested") // suggested | confirmed | rejected
  mfRationale String          @default("") // Maria's per-mapping reasoning: how the differentiator's MF principle applies to this specific audience priority
  createdAt   DateTime        @default(now())
}

// ─── Tier Statements ────────────────────────────────────

model Tier1Statement {
  id       String         @id @default(cuid())
  draftId  String         @unique
  draft    ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  text     String

  cellVersions CellVersion[]
}

model Tier2Statement {
  id            String         @id @default(cuid())
  draftId       String
  draft         ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  text          String
  sortOrder     Int            @default(0)
  priorityId    String?
  priority      Priority?      @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  categoryLabel String         @default("")

  tier3Bullets Tier3Bullet[]
  cellVersions CellVersion[]
}

model Tier3Bullet {
  id        String         @id @default(cuid())
  tier2Id   String
  tier2     Tier2Statement @relation(fields: [tier2Id], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int            @default(0)

  cellVersions CellVersion[]
}

// ─── Five Chapter Story ─────────────────────────────────

model FiveChapterStory {
  id          String         @id @default(cuid())
  draftId     String
  draft       ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  medium      String         // "email" | "blog" | "social" | "landing_page" | "in_person" | "press_release" | "newsletter" | "report"
  customName    String         @default("")
  sourceStoryId String?
  cta         String
  emphasis    String         @default("")
  stage       String         @default("chapters") // "chapters" | "joined" | "blended"
  joinedText  String         @default("")
  blendedText String         @default("")
  version     Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  chapters      ChapterContent[]
  storyVersions StoryVersion[]
}

model ChapterContent {
  id         String           @id @default(cuid())
  storyId    String
  story      FiveChapterStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapterNum Int              // 1-5
  title      String
  content    String

  chapterVersions ChapterVersion[]

  @@unique([storyId, chapterNum])
}

// ─── Version History ────────────────────────────────────

model CellVersion {
  id           String          @id @default(cuid())
  tier1Id      String?
  tier1        Tier1Statement? @relation(fields: [tier1Id], references: [id], onDelete: Cascade)
  tier2Id      String?
  tier2        Tier2Statement? @relation(fields: [tier2Id], references: [id], onDelete: Cascade)
  tier3Id      String?
  tier3        Tier3Bullet?    @relation(fields: [tier3Id], references: [id], onDelete: Cascade)
  text         String
  versionNum   Int
  changeSource String          @default("manual") // manual | ai_generate | poetry_pass | refine | magic_hour
  createdAt    DateTime        @default(now())
}

model TableVersion {
  id         String         @id @default(cuid())
  draftId    String
  draft      ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  snapshot   Json
  label      String
  versionNum Int
  createdAt  DateTime       @default(now())
}

model StoryVersion {
  id         String           @id @default(cuid())
  storyId    String
  story      FiveChapterStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  snapshot   Json
  label      String
  versionNum Int
  createdAt  DateTime         @default(now())
}

// ─── Conversation History ───────────────────────────────

model ConversationMessage {
  id        String         @id @default(cuid())
  draftId   String
  draft     ThreeTierDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  step      Int
  role      String         // "user" | "assistant"
  content   String
  createdAt DateTime       @default(now())
}

// ─── Assistant Messages ────────────────────────────────

model AssistantMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant"
  content   String
  context   Json     @default("{}")
  action    String?
  createdAt DateTime @default(now())
}

// ─── Share Links ───────────────────────────────────────

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique
  draftId   String?
  storyId   String?
  createdBy String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── Chapter Versions ──────────────────────────────────

model ChapterVersion {
  id               String         @id @default(cuid())
  chapterContentId String
  chapter          ChapterContent @relation(fields: [chapterContentId], references: [id], onDelete: Cascade)
  title            String
  content          String
  versionNum       Int
  changeSource     String         @default("manual")
  createdAt        DateTime       @default(now())
}

// ─── Express Flow Jobs (Maria 3.0) ─────────────────────
// Additive to 2.5. Stores the async pipeline state for Express Flow commits.
// The frontend polls GET /api/express/status/:jobId to show progress, and the
// resultStoryId points at the finished FiveChapterStory when status === 'complete'.
model ExpressJob {
  id              String   @id @default(cuid())
  userId          String
  workspaceId     String
  draftId         String?
  status          String   @default("pending")
  stage           String   @default("")
  progress        Int      @default(0)
  error           String   @default("")
  interpretation  Json
  resultStoryId   String?
  // V4 multi-audience variants. When the interpretation returns 2+ audiences,
  // commitInterpretation creates a ThreeTierDraft per audience (all sharing
  // the same Offering) and the pipeline generates one FiveChapterStory per
  // draft. draftId + resultStoryId still point at the primary (first
  // audience) so the single-variant code path is untouched; variantDraftIds
  // and variantStoryIds hold the full list in audience order. Single-audience
  // jobs leave these null.
  variantDraftIds Json?
  variantStoryIds Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
